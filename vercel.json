{
  "version": 2,
  "builds": [
    { "src": "api/generate-report.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "engines.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate-report", "dest": "/api/generate-report.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
